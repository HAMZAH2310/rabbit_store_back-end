{
    "compilerOptions": {
        /* Language and Environment */
        "target": "esnext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "types": [
            "node"
        ],
        "rootDir": "./src",
        "outDir": "./dist",
        /* Modules */
        "verbatimModuleSyntax": true,
        "isolatedModules": true,
        "allowImportingTsExtensions": false,
        /* Interop Constraints */
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        /* Type Checking */
        "strict": true,
        "skipLibCheck": true,
        "noUncheckedIndexedAccess": true,
        /* Source Maps */
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}